# Database
DATABASE_URL=sqlite:///./finrelief.db

# AI / LLM integration — Google Gemini API
# Get a free key at https://aistudio.google.com/app/apikey
# If left blank, the app automatically uses the rule-based fallback
# engine instead of a live Gemini call — see app/services/fallback.py
GOOGLE_API_KEY=

# JWT Authentication (Epic 5: Secure Session Management)
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS
FRONTEND_ORIGIN=http://localhost:5173
